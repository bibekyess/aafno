# Dev-cloud generation config (D2, FR-8, FR-11). Copy to `.env.local` (gitignored) to enable the
# "Generate answer (dev-cloud)" button. Never commit real values — AGENTS.md prohibits committing
# secrets. This path is dev-only and guarded by the `__DEV_CLOUD__` build define (see
# vite.config.ts and adr/2026-07-05-dev-cloud-compile-time-exclusion.md).

# Base URL of an OpenAI-compatible endpoint (no trailing slash). Example: a local llama.cpp
# server, LM Studio, or any hosted OpenAI-compatible provider.
VITE_DEV_CLOUD_BASE_URL=http://localhost:8000

# Model name as understood by the endpoint above.
VITE_DEV_CLOUD_MODEL=gpt-4o-mini

# API key, if the endpoint requires one. Leave blank for local servers that don't check it.
VITE_DEV_CLOUD_API_KEY=
